meta {
  name: 06-202-failed-quarantine-callback
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{callbackZReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "reference": "{{upscanReference}}",
    "fileStatus": "FAILED",
    "failureDetails": {
      "failureReason": "QUARANTINE",
      "message": "Eicar-Test-Signature"
    }
  }
}

assert {
  res.status: eq 202
}
