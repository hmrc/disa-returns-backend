meta {
  name: 13-404-missing-service-prefix
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/monthly/upscan/callback/{{callbackZReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "reference": "{{upscanReference}}",
    "fileStatus": "READY",
    "downloadUrl": "{{downloadUrl}}",
    "uploadDetails": {
      "fileName": "{{fileName}}",
      "fileMimeType": "{{csvMimeType}}",
      "uploadTimestamp": "{{uploadTimestamp}}",
      "checksum": "{{checksum}}",
      "size": {{fileSize}}
    }
  }
}

assert {
  res.status: eq 404
}
