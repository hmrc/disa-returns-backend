meta {
  name: 07-202-failed-rejected-callback
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{callbackZReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "reference": "{{upscanReference}}",
    "fileStatus": "FAILED",
    "failureDetails": {
      "failureReason": "REJECTED",
      "message": "MIME type [application/zip] is not allowed for service: [disa-returns-frontend]"
    }
  }
}

assert {
  res.status: eq 202
}
