meta {
  name: 11-400-malformed-json
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{callbackZReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  invalid-json
}

assert {
  res.status: eq 400
}
