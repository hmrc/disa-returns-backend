meta {
  name: 04-400-invalid-update-value
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}{{servicePath}}/monthly/{{zReference}}/{{taxYear}}/{{month}}/nilReturn
  body: json
  auth: none
}

