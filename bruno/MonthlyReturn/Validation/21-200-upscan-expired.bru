meta {
  name: 21-200-upscan-expired
  type: http
  seq: 21
}

get {
  url: {{baseUrl}}{{servicePath}}/monthly/{{callbackZReference}}/{{taxYear}}/{{month}}/files/{{upscanReference}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

script:pre-request {
  bru.setVar("validationFileName", "upscan-expired.csv");
  bru.setVar("upscanReference", "validation-upscan-expired");
  bru.setVar("callbackZReference", `Z${((Date.now() + Math.floor(Math.random() * 1000)) % 10000).toString().padStart(4, "0")}`);
  bru.setVar("validationMimeType", bru.getEnvVar("csvMimeType"));
  bru.setVar("validationChecksum", "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855");
  bru.setVar("validationFileSize", 0);
  bru.setVar("validationDownloadUrlOverride", `${bru.getEnvVar("baseUrl")}${bru.getEnvVar("servicePath")}/test-only/file-upload/monthly-expired-download`);
  bru.setVar("expectedUploadStatus", "UPSCAN_EXPIRED");
  
  bru.setVar("runValidationHelpers", "true");
  
  const response = await bru.runRequest("TestOnly/ValidationHelpers/01-202-ready-validation-callback");
  if (response.status !== 202) {
    throw new Error(`Expected READY callback to respond with 202, got ${response.status}`);
  }
  const waitResponse = await bru.runRequest("TestOnly/ValidationHelpers/02-200-wait-for-validation-processing");
  if (waitResponse?.status !== 200) {
    throw new Error(`Expected validation processing wait to respond with 200, got ${waitResponse?.status}`);
  }
  bru.setVar("validationDownloadUrlOverride", "");
}

tests {
  test("marked as upscan expired", function() {
    const responseBody = res.body ?? res.getBody();
    const body = typeof responseBody === "string" ? JSON.parse(responseBody) : responseBody;
    expect(body.status).to.equal("UPSCAN_EXPIRED");
    expect(body.fileUploadDetails.fileName).to.equal(bru.getVar("validationFileName"));
    expect(body.fileUploadDetails.validation).to.equal(undefined);
    expect(body.fileUploadDetails.objectStoreFileLocation).to.equal(undefined);
    expect(body.fileUploadDetails.objectStoreFileErrorsLocation).to.equal(undefined);
  });
}
