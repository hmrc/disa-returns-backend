meta {
  name: 06-200-garbage-invalid-xlsx-processed
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}{{servicePath}}/monthly/{{callbackZReference}}/{{taxYear}}/{{month}}/files/{{upscanReference}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

script:pre-request {
  bru.setVar("validationFileName", "garbage-invalid.xlsx");
  bru.setVar("upscanReference", "validation-garbage-invalid-xlsx");
  bru.setVar("callbackZReference", `Z${((Date.now() + Math.floor(Math.random() * 1000)) % 10000).toString().padStart(4, "0")}`);
  bru.setVar("validationMimeType", bru.getEnvVar("xlsxMimeType"));
  bru.setVar("validationChecksum", "b97111bd85b79f2d41d8b4766c7fa6c156b55545c5cd6cdb94486cc0cd95c3ae");
  bru.setVar("validationFileSize", 24);
  bru.setVar("expectedUploadStatus", "VALIDATION_FAILURE");
  bru.setVar("expectedValidationStatus", "InvalidFile");
  bru.setVar("expectedRowsValidated", 0);
  bru.setVar("expectedValidationErrors", 0);
  bru.setVar("expectedInlineErrors", "[]");
  
  bru.setVar("runValidationHelpers", "true");
  
  const response = await bru.runRequest("TestOnly/ValidationHelpers/01-202-ready-validation-callback");
  if (response.status !== 202) {
    throw new Error(`Expected READY callback to respond with 202, got ${response.status}`);
  }
  const waitResponse = await bru.runRequest("TestOnly/ValidationHelpers/02-200-wait-for-validation-processing");
  if (waitResponse?.status !== 200) {
    throw new Error(`Expected validation processing wait to respond with 200, got ${waitResponse?.status}`);
  }
}

tests {
  test("processed as expected", function() {
    const responseBody = res.body ?? res.getBody();
    const body = typeof responseBody === "string" ? JSON.parse(responseBody) : responseBody;
    const details = body.fileUploadDetails;
    const validation = details.validation;
    expect(body.status).to.equal(bru.getVar("expectedUploadStatus"));
    expect(details.fileName).to.equal(bru.getVar("validationFileName"));
    expect(validation.status).to.equal(bru.getVar("expectedValidationStatus"));
    expect(validation.rowsValidated).to.equal(Number(bru.getVar("expectedRowsValidated")));
    expect(validation.validationErrors).to.equal(Number(bru.getVar("expectedValidationErrors")));
    expect(validation.inlineErrors ?? []).to.deep.equal(JSON.parse(bru.getVar("expectedInlineErrors")));
    expect(details.objectStoreFileLocation).to.equal(`disa-returns-backend/${bru.getVar("upscanReference")}`);
    expect(details.objectStoreFileErrorsLocation).to.equal(undefined);
  });
}
