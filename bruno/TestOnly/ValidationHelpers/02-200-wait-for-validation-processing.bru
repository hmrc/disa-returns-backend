meta {
  name: 02-200-wait-for-validation-processing
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}{{servicePath}}/monthly/{{callbackZReference}}/{{taxYear}}/{{month}}/files/{{upscanReference}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

script:pre-request {
  const maxAttempts = 15;
  const pollIntervalMs = Number(bru.getEnvVar("validationProcessingPollIntervalMs") ?? 1000);
  const expectedStatus = bru.getVar("expectedUploadStatus");
  const url = `${bru.getEnvVar("baseUrl")}${bru.getEnvVar("servicePath")}/monthly/${bru.getVar("callbackZReference")}/${bru.getEnvVar("taxYear")}/${bru.getEnvVar("month")}/files/${bru.getVar("upscanReference")}`;
  let lastStatus = "not polled";
  
  const clockResponse = await bru.runRequest("TestOnly/Clock/03-200-reset-clock");
  if (clockResponse.status !== 200) {
    throw new Error(`Expected clock reset to respond with 200, got ${clockResponse.status}`);
  }
  
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      const response = await bru.sendRequest({ method: "GET", url, timeout: 3000 });
      lastStatus = response.data?.status ?? "missing status";
  
      if (lastStatus === expectedStatus) {
        return;
      }
    } catch (error) {
      lastStatus = `HTTP ${error.response?.status ?? "no response"}`;
    }
  
    if (attempt < maxAttempts) {
      await new Promise(resolve => setTimeout(resolve, pollIntervalMs));
    }
  }
  
  throw new Error(`Expected validation status [${expectedStatus}] after ${maxAttempts} poll attempts, last status was [${lastStatus}]. If this stays at [UPSCAN_SUCCESS], the MonthlyReturnWorkItemJob is not processing validation work items. Check backend logs for [MonthlyReturnWorkItemJob][processWorkItem] and restart backend after object-store/internal-auth are healthy. URL: ${url}. Setup return [${bru.getVar("validationSetupReturnStatus")}] ${bru.getVar("validationSetupReturnUrl")}. Setup file upload [${bru.getVar("validationSetupFileUploadStatus")}] ${bru.getVar("validationSetupFileUploadUrl")}`);
}
