meta {
  name: 01-202-ready-validation-callback
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{callbackZReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "reference": "{{upscanReference}}",
    "fileStatus": "READY",
    "downloadUrl": "{{validationDownloadUrl}}",
    "uploadDetails": {
      "fileName": "{{validationFileName}}",
      "fileMimeType": "{{validationMimeType}}",
      "uploadTimestamp": "{{uploadTimestamp}}",
      "checksum": "{{validationChecksum}}",
      "size": {{validationFileSize}}
    }
  }
}

script:pre-request {
  const baseUrl = bru.getEnvVar("baseUrl");
  const servicePath = bru.getEnvVar("servicePath");
  
  if (bru.getVar("runValidationHelpers") !== "true") {
    req.setMethod("GET");
    req.setUrl(`${baseUrl}${servicePath}/test-only/clock`);
    return;
  }
  
  const zReference = bru.getVar("callbackZReference");
  const taxYear = bru.getEnvVar("taxYear");
  const month = bru.getEnvVar("month");
  const uploadReference = bru.getVar("upscanReference");
  const validationDownloadUrlOverride = bru.getVar("validationDownloadUrlOverride");
  const validationDownloadUrl = validationDownloadUrlOverride || `${baseUrl}${servicePath}/test-only/file-upload/monthly/${bru.getVar("validationFileName")}`;
  bru.setVar("validationDownloadUrl", validationDownloadUrl);
  
  const clockResponse = await bru.runRequest("TestOnly/Clock/04-200-set-clock-inside-declaration-period");
  
  if (clockResponse.status !== 200) {
    throw new Error(`Expected clock setup to respond with 200, got ${clockResponse.status}`);
  }
  
  const clearWorkItemsResponse = await bru.runRequest("TestOnly/MonthlyReturnFileUploadWorkItems/01-204-clear-work-items");
  
  if (clearWorkItemsResponse.status !== 204) {
    throw new Error(`Expected monthly return file-upload work-item cleanup to respond with 204, got ${clearWorkItemsResponse.status}`);
  }
  
  const clearReturnsResponse = await bru.runRequest("TestOnly/MonthlyReturns/01-204-clear-monthly-returns");
  
  if (clearReturnsResponse.status !== 204) {
    throw new Error(`Expected monthly returns cleanup to respond with 204, got ${clearReturnsResponse.status}`);
  }
  
  const returnUrl = `${baseUrl}${servicePath}/monthly/${zReference}/${taxYear}/${month}`;
  bru.setVar("validationSetupReturnUrl", returnUrl);
  const returnResponse = await bru.sendRequest({ method: "POST", url: returnUrl, headers: { "Content-Type": "application/json" }, data: { nilReturn: false }, timeout: 3000 });
  bru.setVar("validationSetupReturnStatus", String(returnResponse.status));
  
  if (returnResponse.status !== 201) {
    throw new Error(`Expected monthly return setup to respond with 201, got ${returnResponse.status}. URL: ${returnUrl}`);
  }
  
  const fileUploadUrl = `${returnUrl}/files`;
  bru.setVar("validationSetupFileUploadUrl", fileUploadUrl);
  const response = await bru.sendRequest({ method: "POST", url: fileUploadUrl, headers: { "Content-Type": "application/json" }, data: { reference: uploadReference }, timeout: 3000 });
  bru.setVar("validationSetupFileUploadStatus", String(response.status));
  
  if (response.status !== 201) {
    throw new Error(`Expected file upload setup to respond with 201, got ${response.status}. URL: ${fileUploadUrl}`);
  }
}
