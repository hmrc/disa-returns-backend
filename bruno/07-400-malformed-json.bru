meta {
  name: 07-400-malformed-json
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{zReference}}/{{taxYear}}/{{month}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  invalid-json
}

assert {
  res.status: eq 400
}
