meta {
  name: 08-415-unsupported-media-type
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}{{servicePath}}/monthly/upscan/callback/{{zReference}}/{{taxYear}}/{{month}}
  body: text
  auth: none
}

headers {
  Content-Type: text/plain
}

body:text {
  invalid-json
}

assert {
  res.status: eq 415
}
